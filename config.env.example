# ============================================================
# MikroTik RouterOS — Configuración de conexión (EJEMPLO)
# ============================================================
# Copia este archivo como config.env y completa con tus datos:
#
#   cp mikrotik/config.env.example mikrotik/config.env
#
# ⚠️  config.env está en .gitignore y NUNCA se sube al repo.
# ============================================================

MIKROTIK_HOST=192.168.X.X
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=tu_contraseña_aqui

# Opcionales:
# MIKROTIK_TIMEOUT=15          # segundos de espera para operaciones de red
# MIKROTIK_LAN_PREFIX=192.168.5.   # fuerza el prefijo LAN (normalmente se detecta solo)

# ── Panel web (docker compose) ──────────────────────────────
# Contraseña de acceso al panel (NO es la del router).
# Genera el hash con:  python3 backend/generar_hash.py
# APP_PASSWORD_HASH=pbkdf2_sha256$240000$...
# APP_SESSION_TTL=43200        # duración de la sesión en segundos (12 h)
# APP_WS_INTERVALO=3           # segundos entre muestreos de los WebSockets
